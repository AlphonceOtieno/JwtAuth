# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/jwtauthentication

# JWT secrets
JWT_SECRET=your_jwt_secret_here
REFRESH_TOKEN_SECRET=your_refresh_secret_here
ADMIN_EMAIL=admin@example.com

# Email provider settings
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_smtp_user@example.com
EMAIL_PASS=your_smtp_password
EMAIL_FROM="Your App Name <no-reply@example.com>"

# MPESA credentials
CONSUMER_KEY=your_mpesa_consumer_key
CONSUMER_SECRET=your_mpesa_consumer_secret
BUSINESS_SHORTCODE=your_short_code
PASSKEY=your_pass_key
CALLBACK_URL=https://your-server.com/api/mpesa/callback
ACCOUNT_REFERENCE=CompanyXLTD
TRANSACTION_DESC=Payment request
